    "Match History the app couldn't open is kept here, set aside intact. Restore adds its matches back without changing the ones you already have.": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Históricos de Partidas que o app não conseguiu abrir ficam guardados aqui, intactos. Restaurar adiciona as partidas de volta sem alterar as que você já tem."
          }
        }
      }
    },
